#!/usr/bin/env bash

set -Eeuo pipefail

error_handler() {
  local rc=$?
  local i
  [ "$rc" -eq 0 ] && return 0

  local src="${BASH_SOURCE[1]:-${BASH_SOURCE[0]}}"
  local line
  line=$(sed -n "${BASH_LINENO[0]}p" "$src" 2>/dev/null || true)

  echo "Error ($rc) at line ${BASH_LINENO[0]} in $src: $BASH_COMMAND" >&2
  [ -n "$line" ] && echo "  > $line" >&2

  for ((i = 1; i < ${#FUNCNAME[@]}; i++)); do
    echo "  at ${FUNCNAME[$i]} (${BASH_SOURCE[$i]:-?}:${BASH_LINENO[$i]})" >&2
  done

  exit "$rc"
}

trap error_handler ERR

readonly REPO_NAME="cmc"
readonly REPO_URL="https://github.com/pervezfunctor/${REPO_NAME}.git"
readonly DOT_DIR="${HOME}/.${REPO_NAME}"

readonly LOG_DIR="${HOME}/.${REPO_NAME}-logs"
readonly LOG_FILE="${LOG_DIR}/.${REPO_NAME}.log"
readonly STD_LOG_FILE="${LOG_DIR}/.${REPO_NAME}-std.log"
readonly ERR_LOG_FILE="${LOG_DIR}/.${REPO_NAME}-err.log"
readonly COMBINED_LOG_FILE="${LOG_DIR}/.${REPO_NAME}-combined.log"

init_logs() {
  echo "Initializing log..."

  mkdir -p "${LOG_DIR}"

  rm -f "${LOG_FILE}" 2>/dev/null || true
  rm -f "${STD_LOG_FILE}" 2>/dev/null || true
  rm -f "${ERR_LOG_FILE}" 2>/dev/null || true
  rm -f "${COMBINED_LOG_FILE}" 2>/dev/null || true

  touch "${LOG_FILE}"
  touch "${STD_LOG_FILE}"
  touch "${ERR_LOG_FILE}"
  touch "${COMBINED_LOG_FILE}"
}

log() {
  printf "\033[1;34mℹ %s\033[0m\n" "$*"
  printf "INFO: %s\n" "$*" >>"${LOG_FILE}"
}

warn() {
  printf "\033[1;33m⚠ %s\033[0m\n" "$*"
  printf "WARNING: %s\n" "$*" >>"${LOG_FILE}"
}

error() {
  printf "\033[1;31m✖ %s\033[0m\n" "$*" >&2
  printf "ERROR: %s\n" "$*" >>"${LOG_FILE}"
}

die() {
  error "$*"
  exit 1
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

cmd_check() {
  has_cmd "$1" || die "Command $1 not found. Quitting."
}

cmd_checks() {
  local all_found=true
  for cmd in "$@"; do
    if ! has_cmd "$cmd"; then
      warn "Command $cmd not found."
      all_found=false
    fi
  done
  $all_found || die "Some commands were not found."
}

system_update() {
  log "Updating system packages"
  sudo pacman -Syyu --noconfirm
}

si() {
  log "Installing packages..."
  sudo pacman -S --needed --noconfirm "$@"
}

dotfiles_clone() {
  has_cmd git || si git
  cmd_check git

  git config --global init.defaultBranch main

  if [ ! -d "$DOT_DIR" ]; then
    log "Cloning dotfiles to $DOT_DIR."
    git clone "$REPO_URL" "$DOT_DIR" || die "Failed to clone $REPO_URL"
    [ ! -d "$DOT_DIR" ] && die "Dotfiles repo not found. Quitting."
    return 0
  fi

  if ! git -C "$DOT_DIR" rev-parse --is-inside-work-tree &>/dev/null; then
    die "$DOT_DIR exists but is not a git repo."
  fi

  if [ -d "$DOT_DIR/.git/rebase-merge" ] || [ -d "$DOT_DIR/.git/rebase-apply" ]; then
    die "Dotfiles repo is mid-rebase. Aborting."
  fi

  if [ -n "$(git -C "$DOT_DIR" status --porcelain)" ]; then
    warn "Dotfiles repo dirty. Skipping update."
    return 0
  fi

  log "Dotfiles repo clean. Pulling latest changes."
  if ! git -C "$DOT_DIR" pull --rebase; then
    warn "Rebase failed. Aborting."

    if ! git -C "$DOT_DIR" rebase --abort; then
      die "Failed to abort rebase. Repo may be in a broken state."
    fi

    log "Rebase aborted cleanly."
  fi
}

pixi_install() {
  has_cmd pixi && return 0
  cmd_check curl

  log "Installing pixi..."
  curl -fsSL https://pixi.sh/install.sh | sh
  cmd_check pixi
}

pixi_packages_install() {
  cmd_check pixi

  log "Installing pixi packages..."
  pixi global install carapace mask
}

sync_dotfiles() {
  cmd_check rsync
  if ! [ -d "$DOT_DIR" ]; then
    error "Dotfiles repo not found. Skipping sync."
    return
  fi

  local backup_dir="${HOME}/.rsync-backups/$(date +%Y%m%d_%H%M%S)"
  log "Syncing dotfiles (backups: $backup_dir)"
  rsync -a --backup --backup-dir="$backup_dir" "$DOT_DIR/.config/" "$HOME/.config/"
  rsync -a --backup --backup-dir="$backup_dir" "$DOT_DIR/.local/bin/" "$HOME/.local/bin/"
}

restore_dotfiles() {
  local backup_root="${HOME}/.rsync-backups"
  cmd_check rsync
  [ -d "$backup_root" ] || die "No backups found at $backup_root"

  cmd_check fzf
  local selected
  selected=$(
    ls -1 "$backup_root" | sort -r | fzf --prompt="Select backup to restore> "
  ) || die "No backup selected"

  local backup_dir="$backup_root/$selected"
  log "Restoring dotfiles from $selected"
  rsync -a "$backup_dir/" "$HOME/"
}

prompt_yn() {
  local prompt="$1"
  local response
  printf "\033[36m? %s\033[0m \033[33m[y/N]\033[0m " "$prompt"
  read -r response
  [[ "$response" =~ ^[Yy](es)?$ ]]
}

docker_install() {
  if has_cmd incus; then
    if ! prompt_yn "docker does not work well with incus. Still continue?"; then
      return
    fi
  fi

  log "Installing docker..."
  si docker docker-compose

  log "Adding user to docker group"
  sudo usermod -aG docker "$USER"

  log "Installing lazydocker"
  pixi global install lazydocker
}

incus_install() {
  if has_cmd docker; then
    if ! prompt_yn "incus does not work well with docker. Still continue?"; then
      return
    fi
  fi

  log "Installing incus..."
  si incus incus-tools incus-ui

  log "Adding user to incus groups"
  sudo usermod -aG incus "$USER" || true
  sudo usermod -aG incus-admin "$USER" || true

  log "Enabling incus socket"
  sudo systemctl enable --now incus.socket || true

  log "Configuring firewalld for incus"
  if has_cmd firewall-cmd; then
    sudo firewall-cmd --zone=trusted --change-interface=incusbr0 --permanent
    sudo firewall-cmd --reload
  elif has_cmd ufw; then
    sudo ufw allow in on incusbr0
    sudo ufw route allow in on incusbr0
    sudo ufw route allow out on incusbr0
  fi

  log "Incus configured. Reboot your system and run  'incus.nu init'"
}

rust_install() {
  if has_cmd rustup; then
    log "rustup is already installed"
    return
  fi

  log "Installing rustup..."
  curl -fsSL https://sh.rustup.rs | sh -s -- -y
}

vp_install() {
  if has_cmd vp; then
    log "vp already installed"
    return
  fi

  log "Installing vite plus..."
  curl -fsSL https://vite.plus | bash
  export PATH="$HOME/.vite-plus/bin:$PATH"
  vp env install latest
  vp install -g pnpm
}

nvim_astro() {
  log "Installing Neovim..."
  si neovim

  log "Configuring AstroNvim..."

  local nvim="$HOME/.config/nvim"
  local dirs=(
    "$nvim"
    "$HOME/.local/share/nvim"
    "$HOME/.local/state/nvim"
    "$HOME/.cache/nvim"
  )

  if [ -d "$nvim" ] && ! prompt_yn "Found existing nvim config. Replace with AstroNvim?"; then
    return
  fi

  for dir in "${dirs[@]}"; do
    [ ! -d "$dir" ] && continue
    trash "$dir" 2>/dev/null || rm -rf "$dir"
  done

  git clone --depth 1 https://github.com/AstroNvim/template "$nvim"
  rm -rf "$nvim/.git"
}

uv_install() {
  if has_cmd uv; then
    log "uv already installed"
  else
    log "Installing uv..."
    curl -fsSL https://astral.sh/uv/install.sh | bash
  fi

  if ! has_cmd pipx; then
    log "Installing pipx with uv..."
    uv tool install pipx
  fi
}

ai_cli_install() {
  log "Installing opencode"
  curl -fsSL https://opencode.ai/install | bash

  log "Installing chatgpt cli"
  curl -fsSL https://chatgpt.com/codex/install.sh | sh

  log "Installing antigravity cli"
  curl -fsSL https://antigravity.google/cli/install.sh | bash

  log "Installing claude"
  curl -fsSL https://claude.ai/install.sh | bash
}

distrobox_install() {
  si podman distrobox
}

dev_install() {
  uv_install
  vp_install
  rust_install
  ai_cli_install
}

virt_install() {
  distrobox_install
  libvirt_install
  incus_install
}

get_wallpaper() {
  local filename="$1"
  local wallpaper_dir="$HOME/.config/wallpapers"
  local wallpaper_path="$wallpaper_dir/$filename"

  if [ -f "$wallpaper_path" ]; then
    log "wallpaper $filename already exists"
    return
  fi

  log "Downloading wallpaper..."
  mkdir -p "$wallpaper_dir"
  curl -fsSL "https://raw.githubusercontent.com/mylinuxforwork/wallpaper/refs/heads/main/$filename" -o "$wallpaper_path"
}

get_wallpapers() {
  get_wallpaper "green_sea.jpg"
  get_wallpaper "desert-red-sun.jpg"
  get_wallpaper "colored-silence.jpg"
}

libvirt_install() {
  local -a packages=(
    virt-install virt-manager virt-viewer dnsmasq libvirt
    qemu-img qemu-tools qemu-full qemu-hw-display-virtio-gpu
    swtpm qemu-hw-display-virtio-gpu-gl openbsd-netcat
  )

  log "Installing libvirt packages..."
  si "${packages[@]}"

  log "Setting up libvirt"

  for group in libvirt qemu libvirt-qemu kvm libvirtd; do
    sudo usermod -aG "$group" "$USER" 2>/dev/null || true
  done

  sudo systemctl enable --now libvirtd 2>/dev/null || true
  sudo systemctl enable --now libvirtd.socket 2>/dev/null || true
  sudo virsh net-autostart default 2>/dev/null || true

  if has_cmd authselect; then
    sudo authselect enable-feature with-libvirt 2>/dev/null || true
  fi
}

packages_install() {
  log "Updating system packages..."
  system_update

  local -a packages=(
    fish gcc git less make sed tar tmux tree duf eza unzip wget zip
    zstd libatomic clang cmake gum entr gcc make pkgconf ninja fd xh
    nushell trash-cli starship fzf bat shfmt bottom difftastic direnv
    htop tmuxp imagemagick jq just lazygit rclone ripgrep rsync sd gdu
    shellcheck tealdeer tectonic television trash-cli zoxide yazi zed
    github-cli flatpak ttf-jetbrains-mono-nerd plocate python-yaml
    fprintd cava matugen kimageformats cups-pk-helper ddcutil
  )

  log "Installing system packages..."
  si "${packages[@]}"

  log "Adding flathub remote"
  flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo --user

  pixi_install
  pixi_packages_install
}

fresh_install() {
  log "Performing fresh install..."
  packages_install

  dotfiles_clone
  sync_dotfiles

  get_wallpapers
}

help() {
  echo "Usage: $0 [fresh|dev|command]"
  echo "  -h, --help, help      - Show this help message"

  echo "  fresh                 - Perform a fresh install (default)"
  echo "  dev                   - Install dev tools (uv, vp, rust, ai-cli)"
  echo "  astro                 - Install and configure AstroNvim"
  echo "  wallpapers            - Download few wallpapers"

  echo "  virt                  - Install and configure virtualization tools (libvirt, incus, distrobox)"
  echo "  docker                - Install and configure docker(incompatible with incus installation)"

  echo "  packages              - Install essential packages"
  echo "  config                - Sync .config/ to ~/.config/ via rsync"
  echo "  restore               - Restore dotfiles from a backup via fzf"

  echo "  uv                   - Install and configure uv"
  echo "  vp                   - Install and configure vp"
  echo "  rust                 - Install and configure rust"
  echo "  ai-cli               - Install and configure ai-cli"

  echo "  libvirt               - Install virt-manager and configure libvirt"
  echo "  incus                 - Install and configure incus"
  echo "  distrobox             - Install and configure distrobox"
}

main() {
  if [ $# -eq 0 ] || [ "$1" = "fresh" ]; then
    fresh_install
    return 0
  fi

  local opt="$1"
  shift

  if [ "$opt" = "-h" ] || [ "$opt" = "--help" ] || [ "$opt" = "help" ]; then
    help
    return 0
  fi

  case "$opt" in
  "rust")
    rust_install
    ;;
  "vp")
    vp_install
    ;;
  "astro")
    nvim_astro
    ;;
  "uv")
    uv_install
    ;;
  "ai-cli")
    ai_cli_install
    ;;
  "dev")
    dev_install
    ;;
  "virt")
    virt_install
    ;;
  "packages")
    packages_install
    ;;
  "docker")
    docker_install
    ;;
  "distrobox")
    distrobox_install
    ;;
  "incus")
    incus_install
    ;;
  "config")
    sync_dotfiles
    ;;
  "restore")
    restore_dotfiles
    ;;
  "wallpapers")
    get_wallpapers
    ;;
  "libvirt")
    libvirt_install
    ;;
  *)
    die "Unknown option: $opt"
    ;;
  esac
}

export PATH="$HOME/.pixi/bin:$PATH"
init_logs
has_cmd sed || si sed
cmd_check sed

exec > >(tee -a "$STD_LOG_FILE" | tee -a "$COMBINED_LOG_FILE") \
2> >(tee -a "$ERR_LOG_FILE" | tee -a "$COMBINED_LOG_FILE" >&2)
main "$@"
