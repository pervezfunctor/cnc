#!/usr/bin/env nu

def ensure-line [
    file: path
    line: string
    name: string
] {
  if not ($file | path exists) {
    print -e $"($name) ($file | path basename) not found, skipping"
    return
  }

  let raw = (open --raw $file)

  if ($raw | lines | any {|l| $l == $line }) {
      print $"($name): already configured"
      return
  }

  ($raw
  | lines
  | append $line
  | str join "\n"
  ) | save -f $file

  print $"($name): added"
}

# Niri
ensure-line ($env.HOME | path join ".config" "niri" "config.kdl") 'include "./cfg/custom.kdl"' "niri"

print "Set locale to en_US"
localectl set-locale en_US.UTF-8

if ($env.USER == "pervez") {
  print "git config"
  git config --global user.name "Pervez Iqbal"
  git config --global user.email "pervezfunctor@gmail.com"
  git config --global init.defaultBranch main
}
