#!/usr/bin/env bash

set -euo pipefail

repo="${1:-}"

if [[ -z "$repo" ]]; then
  echo "Usage: gh-clone <owner/repo>" >&2
  exit 1
fi

if [[ ! "$repo" =~ ^[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+$ ]]; then
  echo "error: invalid format '$repo' — expected <owner>/<repo>" >&2
  exit 1
fi

if gh repo clone "$repo" 2>/dev/null; then
  exit 0
fi

url="https://github.com/$repo.git"
echo "gh clone failed, falling back to: git clone $url" >&2
git clone "$url"
